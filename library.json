{
    "name": "InkaLogicModbus",
    "version": "1.0.0",
    "description": "Modbus RTU master library for ESP32 using ESP-IDF UART and freemodbus. Supports FC01-FC06, FC0F, FC10, FC16, FC17 over RS-485.",
    "keywords": "modbus, rtu, rs485, esp32, master, uart, freemodbus, serial",
    "repository": {
        "type": "git",
        "url": "https://github.com/boxlink/INKALOGIC.git"
    },
    "authors": [
        {
            "name": "InkaLogic",
            "maintainer": true
        }
    ],
    "license": "GPL-3.0-or-later",
    "frameworks": "arduino",
    "platforms": "espressif32",
    "headers": "inkaLogicModbus.h",
